            <sortOrder>0</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>After retrieving sites, call Get Scorecard
   Summary for the top three results and present
   each with site name, address, demand score,
   competition level, blind spot status, and
   expected Year 1 revenue.</description>
