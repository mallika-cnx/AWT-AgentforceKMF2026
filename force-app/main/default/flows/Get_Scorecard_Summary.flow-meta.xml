        <label>Set Address Not Found Message</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_ScorecardText</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>No site found matching the address: {!var_AddressString}. Try using the site name or a different address format.</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_Found</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Site_Found_Status</name>
        <label>Site Found Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_ScorecardText</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>No site record found for the provided Site ID. Please check the ID and try again.</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_Found</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Records_by_Address</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Plain_Text_or_Formatted</name>
        <label>Plain Text or Formatted</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Formatted_Score_Card</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Formatted</defaultConnectorLabel>
        <rules>
            <name>Plain</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_PlainText</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Plain_Score_Card</targetReference>
            </connector>
            <label>Plain</label>
        </rules>
    </decisions>
    <decisions>
        <name>Site_ID_or_Address</name>
        <label>Site ID or Address</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Site_Found_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Address String (default outcome)</defaultConnectorLabel>
        <rules>
            <name>Site_Id_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_SiteId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Records_by_ID</targetReference>
            </connector>
            <label>Site Id Present</label>
        </rules>
    </decisions>
    <decisions>
        <name>Was_Projection_Found</name>
        <label>Was Projection Found</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Proceed_with</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Projection (default)</defaultConnectorLabel>
        <rules>
            <name>Projection_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Financial_Projection.Expected_Revenue_Yr1__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Plain_Text_or_Formatted</targetReference>
            </connector>
            <label>Projection Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Was_Scorecard_Found</name>
        <label>Was Scorecard Found</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_Value</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Scorecard (default)</defaultConnectorLabel>
        <rules>
            <name>Scorecard_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Scorecard.Demand_Score__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Financial_Projection</targetReference>
            </connector>
            <label>Scorecard Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Was_Site_Found_by_Address</name>
        <label>Was Site Found by Address</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Address_Not_Found_Message</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Found (default)</defaultConnectorLabel>
        <rules>
            <name>Site_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_SiteRecord.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Scorecard</targetReference>
            </connector>
            <label>Site Found</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>formula_IsPinCode</name>
        <dataType>Boolean</dataType>
        <expression>AND(
  LEN({!var_SiteId}) &gt;= 5,
  LEN({!var_SiteId}) &lt;= 8,
  ISNUMBER({!var_SiteId})
)</expression>
    </formulas>
    <interviewLabel>Get Scorecard Summary {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Get Scorecard Summary</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Financial_Projection</name>
        <label>Get Financial Projection</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Was_Projection_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Potential_Site__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_SiteRecord.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Financial_Projection__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Records_by_Address</name>
        <label>Get Records by Address</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Was_Site_Found_by_Address</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Full_Address__c</field>
            <operator>Contains</operator>
            <value>
                <elementReference>var_AddressString</elementReference>
            </value>
        </filters>
        <filters>
            <field>City__c</field>
            <operator>Contains</operator>
            <value>
                <elementReference>var_AddressString</elementReference>
            </value>
        </filters>
        <filters>
            <field>PIN_Code__c</field>
            <operator>EqualTo</operator>
