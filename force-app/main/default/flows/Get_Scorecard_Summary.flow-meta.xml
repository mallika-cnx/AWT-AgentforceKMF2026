                <elementReference>var_AddressString</elementReference>
            </value>
        </filters>
        <object>Potential_Site__c</object>
        <outputReference>var_SiteRecord</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Full_Address__c</queriedFields>
        <sortField>Demand_Score__c</sortField>
        <sortOrder>Desc</sortOrder>
    </recordLookups>
    <recordLookups>
        <name>Get_Records_by_ID</name>
        <label>Get Records by ID</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Scorecard</targetReference>
