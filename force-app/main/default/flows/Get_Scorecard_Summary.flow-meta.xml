            </value>
        </filters>
        <filters>
            <field>Address__StateCode__s</field>
            <operator>Contains</operator>
            <value>
                <elementReference>var_SiteId</elementReference>
            </value>
        </filters>
        <filters>
            <field>State__c</field>
            <operator>Contains</operator>
            <value>
                <elementReference>var_SiteId</elementReference>
            </value>
        </filters>
        <filters>
            <field>PIN_Code__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_SiteId</elementReference>
            </value>
        </filters>
        <filters>
            <field>Address__PostalCode__s</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_SiteId</elementReference>
            </value>
        </filters>
        <object>Potential_Site__c</object>
        <outputReference>var_SiteRecord</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Full_Address__c</queriedFields>
