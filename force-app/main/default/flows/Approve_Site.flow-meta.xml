    <assignments>
        <name>Add_Approver</name>
        <label>Add Approver</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_ApproverId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$User.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_Expansion_Decision_Record</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Final_Assignment</name>
        <label>Final Assignment</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_Success</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Check_Approver_is_Blank_or_Not</name>
        <label>Check Approver is Blank or Not</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_Expansion_Decision_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Approver is not Blank</defaultConnectorLabel>
        <rules>
            <name>Is_Approver_Blank</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ApproverId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_Approver</targetReference>
            </connector>
            <label>Is Approver Blank</label>
        </rules>
    </decisions>
    <decisions>
        <name>Scorecard_Available</name>
        <label>Scorecard Available</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Scorecard_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Records_Site_Scorecard.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Approver_is_Blank_or_Not</targetReference>
            </connector>
            <label>Scorecard Found</label>
        </rules>
    </decisions>
    <environments>Default</environments>
