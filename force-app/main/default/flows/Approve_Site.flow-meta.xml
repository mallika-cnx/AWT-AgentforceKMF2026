            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Expansion_Decision_Record</name>
        <label>Create Expansion Decision Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignRecordIdToReference>var_DecisionId</assignRecordIdToReference>
        <connector>
            <targetReference>Update_Expansion_Potential_Site_Record</targetReference>
        </connector>
        <inputAssignments>
            <field>Approved_By__c</field>
            <value>
                <elementReference>var_ApproverId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Committed_Capex__c</field>
            <value>
                <elementReference>var_Capex</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Decision_Date__c</field>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Decision_Status__c</field>
            <value>
                <stringValue>Approved</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Remarks__c</field>
            <value>
                <elementReference>var_Remarks</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Site_Score_Card__c</field>
            <value>
                <elementReference>Get_Records_Site_Scorecard.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Target_Open_Date__c</field>
            <value>
                <elementReference>var_OpenDate</elementReference>
            </value>
        </inputAssignments>
        <object>Expansion_Decision__c</object>
    </recordCreates>
    <recordLookups>
        <name>Get_Records_Site_Scorecard</name>
        <label>Get Records Site Scorecard</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Scorecard_Available</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Potential_Site__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_SiteId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Site_Score__c</object>
        <sortField>Scored_Date__c</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Expansion_Potential_Site_Record</name>
        <label>Update Expansion Potential Site Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Final_Assignment</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_SiteId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Site_Status__c</field>
            <value>
                <stringValue>Approved</stringValue>
            </value>
        </inputAssignments>
        <object>Potential_Site__c</object>
    </recordUpdates>
    <runInMode>DefaultMode</runInMode>
    <start>
