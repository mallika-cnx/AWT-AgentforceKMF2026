{
	"name": "salesforcedx-metadata-visualizer-vscode",
	"displayName": "Metadata Visualizer",
	"description": "VS Code Extension to visualize Salesforce metadata with interactive diagrams",
	"version": "1.0.2",
	"publisher": "salesforce",
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#ECECEC",
		"theme": "light"
	},
	"author": "salesforce",
	"license": "BSD-3-Clause",
	"qna": "https://github.com/forcedotcom/salesforce-metadata-visualizer-support/issues",
	"repository": {
		"url": "https://github.com/forcedotcom/salesforce-metadata-visualizer-support"
	},
	"bugs": {
		"url": "https://github.com/forcedotcom/salesforce-metadata-visualizer-support/issues"
	},
	"keywords": [
		"salesforce",
		"metadata",
		"visualizer"
	],
	"engines": {
		"vscode": "^1.86.0",
		"node": ">=18.0.0"
	},
	"categories": [
		"Visualization",
		"Other"
	],
	"activationEvents": [
		"workspaceContains:sfdx-project.json"
	],
	"extensionDependencies": [
		"salesforce.salesforcedx-vscode-core"
	],
	"aiKey": "ec3632a4-df47-47a4-98dc-8134cacbaf7e",
	"o11yUploadEndpoint": "https://794testsite.my.site.com/byolwr/webruntime/log/metrics",
	"enableO11y": "true",
	"main": "./dist/extension.cjs",
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"test": "echo \"Use 'npm run test:integration' for VS Code integration tests\" && exit 0",
		"test:watch": "jest --watch",
		"test:architecture": "jest architecture.test",
		"test:integration": "npm run test-compile && node ./out/test/runTest.js",
		"test:e2e": "npm run test-compile && extest run-tests out/test/e2e/specs/*.e2e.js -o src/test/e2e/e2e-settings.json",
		"test-compile": "tsc -p ./ && npm run copy:e2e-assets",
		"copy:e2e-assets": "node scripts/copy-e2e-assets.js",
		"lint": "eslint src",
		"lint:fix": "eslint src --ext .ts --fix",
		"format": "prettier --write \"src/**/*.ts\" --ignore-path ../../.prettierignore",
		"format:check": "prettier --check \"src/**/*.ts\" --ignore-path ../../.prettierignore",
		"typecheck": "tsc --noEmit",
		"build": "npm run compile",
		"clean": "rimraf dist out",
		"verify": "npm run lint && npm run typecheck && npm run test && npm run build",
		"prepublishOnly": "npm run package"
	},
	"devDependencies": {
		"@eslint/js": "^9.15.0",
		"@salesforce/kit": "^3.2.4",
		"@salesforce/salesforcedx-vscode-test-tools": "^1.2.5",
		"@tony.ganchev/eslint-plugin-header": "^3.1.6",
		"@types/chai": "^4.3.5",
		"@types/jest": "^29.5.14",
		"@types/mocha": "^10.0.10",
		"@types/node": "^18.19.68",
		"@types/vscode": "^1.86.0",
		"@vscode/test-electron": "^2.4.2",
		"@vscode/vsce": "^3.2.1",
		"chai": "^4.3.7",
		"clean-css": "^5.3.3",
		"copy-webpack-plugin": "^13.0.1",
		"eslint": "^9.15.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-jest": "^28.9.0",
		"eslint-plugin-prettier": "^5.2.1",
		"fast-xml-parser": "^5.5.8",
		"glob": "^11.0.0",
		"jest": "^29.7.0",
		"mocha": "^11.7.1",
		"prettier": "^3.4.2",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.1",
		"ts-node": "^10.9.1",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.15.0",
		"vscode-extension-tester": "^8.16.0",
		"webpack": "^5.104.0",
		"webpack-cli": "^6.0.1"
	},
	"dependencies": {
		"@salesforce/metadata-core-sdk": "^1.0.0",
		"@salesforce/metadata-visualizer-core": "^1.0.1"
	},
	"contributes": {
		"commands": [
			{
				"command": "sf.metadata.viz.listPlugins",
				"title": "List Visualizer Plugins",
				"category": "Visualization"
			},
			{
				"command": "sf.metadata.viz.showVisualizer",
				"title": "Visualize",
				"category": "Visualization"
			},
			{
				"command": "sf.metadata.viz.visualizeFullScreen",
				"title": "Full Screen Visualization",
				"category": "Visualization",
				"icon": "$(screen-full)"
			},
			{
				"command": "sf.metadata.viz.getVisualizerInfo",
				"title": "Get visualizer info for file",
				"category": "Visualization"
			},
			{
				"command": "sf.metadata.viz.showVisualizerFromEditorTitle",
				"title": "Visualize",
				"category": "Visualization"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "sf.metadata.viz.visualizeFullScreen",
					"when": "false"
				},
				{
					"command": "sf.metadata.viz.showVisualizer",
					"when": "sf.metadata.viz.ctx.showVisualizationButton"
				},
				{
					"command": "sf.metadata.viz.getVisualizerInfo",
					"when": "false"
				},
				{
					"command": "sf.metadata.viz.showVisualizerFromEditorTitle",
					"when": "false"
				}
			],
			"editor/title": [
				{
					"command": "sf.metadata.viz.showVisualizerFromEditorTitle",
					"group": "navigation@1",
					"when": "sf.metadata.viz.ctx.showVisualizationButton"
				},
				{
					"command": "sf.metadata.viz.visualizeFullScreen",
					"group": "navigation@-10",
					"when": "sf.metadata.viz.ctx.webviewActive && !editorPartMaximizedEditorGroup"
				}
			],
			"editor/context": [
				{
					"command": "sf.metadata.viz.showVisualizer",
					"group": "sf.metadata.visualize",
					"when": "sf.metadata.viz.ctx.showVisualizationButton"
				}
			],
			"explorer/context": [
				{
					"command": "sf.metadata.viz.showVisualizer",
					"group": "sf.metadata.visualize",
					"when": "!explorerResourceIsFolder"
				}
			]
		},
		"configuration": {
			"title": "Metadata Visualizer",
			"properties": {
				"salesforce.metadataVisualizer.autoLoadVisualization": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "Automatically load visualization when switching to visualizable files. When disabled, visualization only opens on explicit button click.",
					"order": 1
				},
				"salesforce.metadataVisualizer.enabledPlugins": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"Data Model": {
							"type": "boolean"
						},
						"Flexipages (Beta)": {
							"type": "boolean"
						}
					},
					"default": {
						"Flexipages (Beta)": false,
						"Data Model": true
					},
					"description": "To show or hide visualizations for a plugin, select or clear the corresponding checkbox and then reload the window.",
					"scope": "resource",
					"order": 2
				}
			}
		}
	},
	"__metadata": {
		"installedTimestamp": 1776737498617,
		"targetPlatform": "undefined",
		"size": 796525
	}
}