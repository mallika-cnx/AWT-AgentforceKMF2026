				<Property Id="Microsoft.VisualStudio.Code.ExtensionPack" Value="salesforce.salesforcedx-vscode-agents,salesforce.salesforcedx-vscode-apex,salesforce.salesforcedx-vscode-apex-testing,salesforce.salesforcedx-vscode-apex-oas,salesforce.salesforcedx-vscode-apex-log,salesforce.salesforcedx-vscode-apex-replay-debugger,salesforce.salesforcedx-einstein-gpt,salesforce.salesforcedx-vscode-core,salesforce.salesforcedx-vscode-lightning,salesforce.salesforcedx-vscode-org,salesforce.salesforcedx-vscode-org-browser,salesforce.salesforcedx-vscode-visualforce,salesforce.salesforcedx-vscode-lwc,salesforce.salesforcedx-vscode-metadata,salesforce.salesforcedx-vscode-services,salesforce.salesforcedx-vscode-soql,salesforce.salesforce-vscode-slds,salesforce.sfdx-code-analyzer-vscode,salesforce.apex-language-server-extension" />
