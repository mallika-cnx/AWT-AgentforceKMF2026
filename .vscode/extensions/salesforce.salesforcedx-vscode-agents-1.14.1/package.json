{
	"name": "salesforcedx-vscode-agents",
	"displayName": "Agentforce DX",
	"description": "Provides a suite of tools to iteratively build, preview, and test agents right in your IDE.",
	"version": "1.14.1",
	"publisher": "Salesforce",
	"o11yUploadEndpoint": "https://794testsite.my.site.com/byolwr/webruntime/log/metrics",
	"enableO11y": "true",
	"productFeatureId": "aJCEE0000007rcH4AQ",
	"repository": {
		"url": "https://github.com/salesforcecli/vsode-agents"
	},
	"icon": "images/agentforce-dx.png",
	"license": "Apache-2.0",
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Extension Packs"
	],
	"main": "lib/src/extension.js",
	"dependencies": {
		"@salesforce/agents": "^1.1.2",
		"@salesforce/core": "^8.28.3",
		"@salesforce/kit": "^3.2.6",
		"@salesforce/types": "^1.7.1",
		"cross-spawn": "^7.0.6",
		"fast-xml-parser": "^5.7.1",
		"prettier": "^3.8.3",
		"semver": "^7.7.4",
		"shelljs": "0.10.0",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/cross-spawn": "^6.0.6",
		"@types/glob": "^8.1.0",
		"@types/jest": "^30.0.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.7.2",
		"@types/react": "^18.2.79",
		"@types/react-dom": "^18.2.25",
		"@types/semver": "^7.7.1",
		"@types/shelljs": "^0.10.0",
		"@types/vscode": "^1.90.0",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.25.12",
		"glob": "^13.0.0",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"jest-junit": "^16.0.0",
		"mocha": "^11.7.5",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"ts-jest": "^29.4.5",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"mocha": {
			"serialize-javascript": "^7.0.3",
			"diff": "^8.0.3"
		}
	},
	"scripts": {
		"postinstall": "npm run install:combined",
		"install:combined": "cd webview && npm install",
		"build": "tsc --build && npm run build:combined",
		"build:combined": "cd webview && npm run build",
		"build:clean": "tsc --build --clean",
		"compile": "npm run build",
		"compile:clean": "tsc --build --clean",
		"reinstall": "git checkout -- package-lock.json && git clean -xfd && npm install",
		"prettier": "prettier --write .",
		"prettier-check": "prettier --check .",
		"lint": "eslint . --ext .ts",
		"update-snapshots": "jest --updateSnapshot",
		"test": "npm run test:backend && npm run test:frontend",
		"test:backend": "jest --coverage",
		"test:frontend": "jest --config jest.config.webview.js --coverage",
		"test:integration": "npm run build && npm run compile:integration && node ./test/integration/out/runTest.js",
		"compile:integration": "tsc -p ./test/integration/tsconfig.json",
		"bundle:extension": "node ./esbuild.config.js",
		"vscode:package": "npm run compile && npm run bundle:extension & npx vsce package",
		"vscode:prepublish_disabled": "npm run update-for-packaging",
		"update-for-packaging": "ts-node scripts/updatePackageJsonForVSIX.ts",
		"vsix:install": "find ./ -name '*.vsix' -exec code --install-extension {}",
		"vsix:install-insiders": "find ./ -name '*.vsix' -exec code-insiders --install-extension {}",
		"reformat": "node scripts/reformat-with-prettier.js"
	},
	"extensionDependencies": [
		"salesforce.salesforcedx-vscode-org",
		"salesforce.salesforcedx-vscode-apex-replay-debugger",
		"salesforce.agent-script-language-client"
	],
	"activationEvents": [
		"workspaceContains:sfdx-project.json"
	],
	"contributes": {
		"languages": [
			{
				"id": "afdx-log",
				"extensions": [
					".afdxlog"
				]
			}
		],
		"grammars": [
			{
				"language": "afdx-log",
				"scopeName": "text.afdx.log",
				"path": "./syntaxes/afdx-log.tmLanguage.json"
			}
		],
		"extensionPack": [
			"salesforce.salesforcedx-vscode-core",
			"salesforce.salesforcedx-vscode-org",
			"salesforce.salesforcedx-vscode-apex-replay-debugger",
			"salesforce.agent-script-language-client"
		],
		"submenus": [
			{
				"id": "sf.agent.combined.view.restartMenu",
				"label": "Restart Options",
				"icon": "$(debug-rerun)"
			}
		],
		"configuration": {
			"title": "Agentforce DX",
			"properties": {
				"salesforce.agentforceDX.showGeneratedData": {
					"type": "boolean",
					"default": true,
					"description": "Show generated data in test results output"
				},
				"salesforce.agentforceDX.skipRetrieve": {
					"type": "boolean",
					"default": false,
					"description": "Skip retrieving agent metadata to your DX project when publishing the authoring bundle to your org."
				}
			}
		},
		"views": {
			"test": [
				{
					"id": "sf.agent.test.view",
					"name": "%agent_test_view_name%",
					"when": "sf:project_opened"
				}
			],
			"agentforce-dx": [
				{
					"id": "sf.agent.combined.view",
					"name": "%agentforce_dx%",
					"type": "webview",
					"when": "sf:project_opened"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "agentforce-dx",
					"title": "Agentforce DX",
					"icon": "images/activity-bar-icon.svg"
				}
			]
		},
		"menus": {
			"sf.agent.combined.view.restartMenu": [
				{
					"command": "sf.agent.combined.view.restart"
				},
				{
					"command": "sf.agent.combined.view.recompileAndRestart"
				}
			],
			"view/title": [
				{
					"command": "sf.agent.combined.view.exportConversation",
					"when": "view == sf.agent.combined.view && agentforceDX:agentSelected && !agentforceDX:sessionStarting && !agentforceDX:sessionError && agentforceDX:hasConversationData",
					"group": "navigation@-1"
				},
				{
					"command": "salesforcedx-vscode-agents.createAiAuthoringBundle",
					"when": "view == sf.agent.combined.view && !agentforceDX:sessionActive && !agentforceDX:sessionStarting && !agentforceDX:canResetAgentView && !agentforceDX:agentSelected",
					"group": "navigation@-1"
				},
				{
					"command": "salesforcedx-vscode-agents.activateAgent",
					"when": "view == sf.agent.combined.view && !agentforceDX:sessionActive && !agentforceDX:sessionStarting && !agentforceDX:canResetAgentView && !agentforceDX:agentSelected",
					"group": "navigation@0"
				},
				{
					"command": "sf.agent.combined.view.activateVersion",
					"when": "view == sf.agent.combined.view && agentforceDX:agentSelected && !agentforceDX:isScriptAgent && !agentforceDX:sessionActive && !agentforceDX:sessionStarting",
					"group": "navigation@0"
				},
				{
					"command": "sf.agent.combined.view.refreshAgents",
					"when": "view == sf.agent.combined.view && !agentforceDX:sessionActive && !agentforceDX:sessionStarting && !agentforceDX:canResetAgentView",
					"group": "navigation@1"
				},
				{
					"command": "sf.agent.combined.view.resetAgentView",
					"when": "view == sf.agent.combined.view && !agentforceDX:sessionActive && !agentforceDX:sessionStarting && agentforceDX:agentSelected && agentforceDX:canResetAgentView",
					"group": "navigation@0"
				},
				{
					"submenu": "sf.agent.combined.view.restartMenu",
					"when": "view == sf.agent.combined.view && agentforceDX:sessionActive && !agentforceDX:sessionStarting && agentforceDX:agentSelected && agentforceDX:isScriptAgent",
					"group": "navigation@0"
				},
				{
					"command": "sf.agent.combined.view.debug",
					"when": "view == sf.agent.combined.view && agentforceDX:sessionActive && !agentforceDX:debugMode && agentforceDX:isLiveMode",
					"group": "navigation@-2"
				},
				{
					"command": "sf.agent.combined.view.debugStop",
					"when": "view == sf.agent.combined.view && agentforceDX:sessionActive && agentforceDX:debugMode && agentforceDX:isLiveMode",
					"group": "navigation@-2"
				},
				{
					"command": "sf.agent.test.view.runAll",
					"when": "never && view == sf.agent.test.view",
					"group": "navigation@1"
				},
				{
					"command": "sf.agent.test.view.refresh",
					"when": "view == sf.agent.test.view",
					"group": "navigation@2"
				},
				{
					"command": "sf.agent.test.view.collapseAll",
					"when": "view == sf.agent.test.view",
					"group": "navigation@3"
				},
				{
					"command": "sf.agent.test.view.toggleGeneratedData.on",
					"when": "view == sf.agent.test.view && agentforceDX:showGeneratedData",
					"group": "navigation@4"
				},
				{
					"command": "sf.agent.test.view.toggleGeneratedData.off",
					"when": "view == sf.agent.test.view && !agentforceDX:showGeneratedData",
					"group": "navigation@4"
				}
			],
			"view/item/context": [
				{
					"command": "sf.agent.test.view.runTest",
					"when": "view == sf.agent.test.view && viewItem =~ /agentTestGroup/",
					"group": "inline"
				},
				{
					"command": "sf.agent.test.view.goToTestResults",
					"when": "view == sf.agent.test.view && viewItem =~ /(agentTest|agentTestGroup)(_Pass|_Skip|\\b)/"
				}
			],
			"editor/context": [
				{
					"command": "salesforcedx-vscode-agents.validateAgent",
					"when": "resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.previewAgent",
					"when": "resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.publishAgent",
					"when": "resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.activateAgent",
					"when": "resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlannerBundle$/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || explorerResourceIsFolder && resourcePath =~ /bots\\/|botVersions\\//",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.deactivateAgent",
					"when": "resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlannerBundle$/ || resourceFilename =~ /.*\\.genAiPlannerBundle/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || explorerResourceIsFolder && resourcePath =~ /bots\\/|botVersions\\//",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.openAgentInOrg",
					"when": "resourceFilename =~ /.*\\.bot-meta\\.xml$/ || resourceFilename =~ /.*\\.genAiPlannerBundle$/ ||  resourceFilename =~ /.*\\.botVersion-meta\\.xml$/ || resourceFilename =~ /.*Planner\\.genAiPlannerBundle$/ || resourceFilename =~ /.*\\.genAiPlanner-meta\\.xml$/ || resourcePath =~ /genAiPlannerBundles/",
					"group": "agent@2"
				},
				{
					"command": "salesforcedx-vscode-agents.openAuthoringBundleInOrg",
					"when": "resourcePath =~ /aiAuthoringBundles/",
					"group": "agent@2"
				}
			],
			"explorer/context": [
				{
					"command": "salesforcedx-vscode-agents.validateAgent",
					"when": "resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.previewAgent",
					"when": "resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.publishAgent",
					"when": "resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.activateAgent",
					"when": "resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlannerBundle$/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || explorerResourceIsFolder && resourcePath =~ /bots\\/|botVersions\\//",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.deactivateAgent",
					"when": "resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlannerBundle$/ || resourceFilename =~ /.*\\.genAiPlannerBundle/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || explorerResourceIsFolder && resourcePath =~ /bots\\/|botVersions\\//",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.createAiAuthoringBundle",
					"when": "explorerResourceIsFolder && resourcePath =~ /aiAuthoringBundles/",
					"group": "agent@1"
				},
				{
					"command": "salesforcedx-vscode-agents.openAgentInOrg",
					"when": "resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlannerBundle$/ || resourceFilename =~ /.*\\.genAiPlannerBundle/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlanner-meta\\.xml/ || resourcePath =~ /genAiPlannerBundles/",
					"group": "agent@2"
				},
				{
					"command": "salesforcedx-vscode-agents.openAuthoringBundleInOrg",
					"when": "resourcePath =~ /aiAuthoringBundles/",
					"group": "agent@2"
				}
			],
			"commandPalette": [
				{
					"command": "salesforcedx-vscode-agents.validateAgent",
					"when": "resourceFilename =~ /.*\\.agent$/"
				},
				{
					"command": "salesforcedx-vscode-agents.previewAgent",
					"when": "resourceFilename =~ /.*\\.agent$/"
				},
				{
					"command": "salesforcedx-vscode-agents.publishAgent",
					"when": "resourceFilename =~ /.*\\.agent$/"
				},
				{
					"command": "salesforcedx-vscode-agents.createAiAuthoringBundle",
					"when": "sf:project_opened"
				},
				{
					"command": "sf.agent.test.view.goToTestResults",
					"when": "false"
				},
				{
					"command": "salesforcedx-vscode-agents.openAgentInOrg",
					"when": "resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlanner-meta\\.xml/"
				},
				{
					"command": "sf.agent.test.view.runAll",
					"when": "false"
				},
				{
					"command": "sf.agent.test.view.runTest",
					"when": "false"
				},
				{
					"command": "sf.agent.test.view.refresh",
					"when": "false"
				},
				{
					"command": "sf.agent.test.view.collapseAll",
					"when": "sf:project_opened"
				}
			]
		},
		"commandPalette": [
			{
				"command": "salesforcedx-vscode-agents.openAgentInOrg",
				"when": "resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlanner-meta\\.xml/"
			},
			{
				"command": "salesforcedx-vscode-agents.activateAgent",
				"when": "sf:project_opened"
			},
			{
				"command": "sf.agent.combined.view.activateVersion",
				"when": "false"
			},
			{
				"command": "salesforcedx-vscode-agents.deactivateAgent",
				"when": "sf:project_opened"
			},
			{
				"command": "sf.agent.selectAndRun",
				"when": "sf:project_opened"
			},
			{
				"command": "sf.agent.test.view.runAll",
				"when": "false"
			},
			{
				"command": "sf.agent.test.view.runTest",
				"when": "false"
			},
			{
				"command": "sf.agent.test.view.refresh",
				"when": "false"
			},
			{
				"command": "sf.agent.test.view.collapseAll",
				"when": "sf:project_opened"
			}
		],
		"commands": [
			{
				"command": "sf.agent.focusView",
				"title": "AFDX: Focus on Agentforce DX Preview"
			},
			{
				"command": "sf.agent.focusTestView",
				"title": "AFDX: Focus on Agent Tests View"
			},
			{
				"command": "sf.agent.startAgent",
				"title": "Start Agent",
				"enablement": "!agentforceDX:sessionActive && !agentforceDX:sessionStarting"
			},
			{
				"command": "sf.agent.selectAndRun",
				"title": "AFDX: Select Agent"
			},
			{
				"command": "sf.agent.combined.view.stop",
				"title": "Stop Agent",
				"icon": "$(stop-circle)",
				"enablement": "agentforceDX:sessionActive || agentforceDX:sessionStarting"
			},
			{
				"command": "sf.agent.combined.view.restart",
				"title": "Restart Only",
				"icon": "$(debug-rerun)",
				"enablement": "agentforceDX:sessionActive || agentforceDX:sessionStarting"
			},
			{
				"command": "sf.agent.combined.view.recompileAndRestart",
				"title": "Compile & Restart",
				"enablement": "agentforceDX:sessionActive || agentforceDX:sessionStarting"
			},
			{
				"command": "sf.agent.combined.view.exportConversation",
				"title": "Save Chat History",
				"icon": "$(arrow-circle-down)"
			},
			{
				"command": "sf.agent.combined.view.refreshAgents",
				"title": "Refresh Agent List",
				"icon": "$(refresh)"
			},
			{
				"command": "sf.agent.combined.view.resetAgentView",
				"title": "Reset",
				"icon": "$(clear-all)"
			},
			{
				"command": "sf.agent.combined.view.debug",
				"title": "Start Debug Mode",
				"icon": "$(bug)",
				"enablement": "(agentforceDX:sessionActive || agentforceDX:sessionStarting) && !agentforceDX:debugMode"
			},
			{
				"command": "sf.agent.combined.view.debugStop",
				"title": "Stop Debug Mode",
				"icon": "$(debug)",
				"enablement": "agentforceDX:debugMode"
			},
			{
				"command": "salesforcedx-vscode-agents.previewAgent",
				"title": "AFDX: Preview This Agent"
			},
			{
				"command": "salesforcedx-vscode-agents.publishAgent",
				"title": "AFDX: Publish This Agent"
			},
			{
				"command": "sf.agent.test.view.goToTestResults",
				"title": "%go_to_test_results%"
			},
			{
				"command": "sf.agent.test.view.refresh",
				"title": "%refresh_test_title%",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "sf.agent.test.view.collapseAll",
				"title": "%collapse_tests_title%",
				"icon": {
					"light": "resources/light/collapse-all.svg",
					"dark": "resources/dark/collapse-all.svg"
				}
			},
			{
				"command": "sf.agent.test.view.runAll",
				"title": "%run_all_tests_title%",
				"icon": {
					"light": "resources/light/play-button.svg",
					"dark": "resources/dark/play-button.svg"
				}
			},
			{
				"command": "sf.agent.test.view.runTest",
				"title": "%run_test_title%",
				"icon": {
					"light": "resources/light/play-button.svg",
					"dark": "resources/dark/play-button.svg"
				}
			},
			{
				"command": "salesforcedx-vscode-agents.openAgentInOrg",
				"title": "%salesforcedx-vscode-agents.openAgentInOrg%"
			},
			{
				"command": "salesforcedx-vscode-agents.openAuthoringBundleInOrg",
				"title": "%salesforcedx-vscode-agents.openAuthoringBundleInOrg%"
			},
			{
				"command": "salesforcedx-vscode-agents.activateAgent",
				"title": "%salesforcedx-vscode-agents.activateAgent%",
				"icon": "$(versions)"
			},
			{
				"command": "sf.agent.combined.view.activateVersion",
				"title": "Activate Version",
				"icon": "$(versions)"
			},
			{
				"command": "salesforcedx-vscode-agents.deactivateAgent",
				"title": "%salesforcedx-vscode-agents.deactivateAgent%"
			},
			{
				"command": "sf.agent.test.view.toggleGeneratedData.on",
				"title": "Hide Generated Data Output",
				"category": "AFDX",
				"icon": {
					"light": "resources/light/check-on.svg",
					"dark": "resources/dark/check-on.svg"
				}
			},
			{
				"command": "sf.agent.test.view.toggleGeneratedData.off",
				"title": "Show Generated Data Output",
				"category": "AFDX",
				"icon": {
					"light": "resources/light/check-off.svg",
					"dark": "resources/dark/check-off.svg"
				}
			},
			{
				"command": "salesforcedx-vscode-agents.validateAgent",
				"title": "AFDX: Validate This Agent"
			},
			{
				"command": "salesforcedx-vscode-agents.createAiAuthoringBundle",
				"title": "AFDX: Create Agent",
				"icon": "$(add)"
			}
		]
	},
	"__metadata": {
		"installedTimestamp": 1777300510754,
		"targetPlatform": "undefined",
