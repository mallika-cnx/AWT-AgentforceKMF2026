{
	"name": "salesforcedx-einstein-gpt",
	"displayName": "Agentforce Vibes",
	"description": "Extension for developing on the Salesforce Platform with the help of generative AI",
	"version": "3.34.0",
	"publisher": "salesforce",
	"aiKey": "ec3632a4-df47-47a4-98dc-8134cacbaf7e",
	"o11yUploadEndpoint": "https://794testsite.my.site.com/byolwr/webruntime/log/metrics",
	"enableO11y": "true",
	"productFeatureId": "aJCEE0000000mCe4AI",
	"qna": "https://github.com/forcedotcom/Einstein-GPT-for-Developers/issues",
	"bugs": {
		"url": "https://github.com/forcedotcom/Einstein-GPT-for-Developers/issues"
	},
	"repository": {
		"url": "https://github.com/forcedotcom/Einstein-GPT-for-Developers"
	},
	"icon": "images/AgentforceVibes.png",
	"license": "BSD-3-Clause",
	"engines": {
		"vscode": "^1.86.0"
	},
	"categories": [
		"Other"
	],
	"scripts": {
		"vscode:prepublish": "npm run compile && npm run bundle:extension && npm run update-for-packaging",
		"compile": "tsc --noEmit && node ./esbuild.js && npm run webview:build",
		"clean": "rimraf dist out .vscode-test test/e2e/results && npm run webview:clean",
		"watch": "tsc --noEmit --watch",
		"postinstall": "npm run webview:install && echo 'Dependencies installed'",
		"prettier": "prettier --write .",
		"prettier-check": "prettier --check .",
		"lint": "eslint .",
		"lint-fix": "eslint --fix . --ignore-pattern \"test/e2e/**/*.ts\"; eslint test/e2e/**/*.ts",
		"update-snapshots": "jest --updateSnapshot",
		"test": "jest --coverage",
		"test:watch": "jest --watch --coverage",
		"test-vsix": "ts-node scripts/installVSIXFromBranch.ts code",
		"test-vsix-insiders": "ts-node scripts/installVSIXFromBranch.ts code-insiders",
		"bundle:extension": "node ./esbuild.js --production",
		"bundle:extension:analyze": "npm run bundle:extension && esbuild-visualizer --template treemap --metadata out/extension-esbuild-metafile.json --filename out/extension-bundle-stats-treemap.html && open out/extension-bundle-stats-treemap.html && esbuild-visualizer --template sunburst --metadata out/extension-esbuild-metafile.json --filename out/extension-bundle-stats-sunburst.html && open out/extension-bundle-stats-sunburst.html",
		"bundle:vsix": "npm run webview:install && npm run compile && npm run webview:build && vsce package --follow-symlinks",
		"update-for-packaging": "ts-node scripts/updatePackageJsonForVSIX.ts",
		"build": "node scripts/build-cline.js",
		"build:vsix": "node scripts/build-cline.js --vsix",
		"check-vsix-size": "ts-node scripts/vsix-size-check/check-vsix-size.ts",
		"pretest:e2e": "npm run compile && npx playwright install --with-deps chromium",
		"test:e2e": "npx playwright test",
		"test:e2e:results": "npx playwright show-report test/e2e/results",
		"sync": "ts-node scripts/cline-sync/main.ts",
		"sync:get-next-release": "ts-node scripts/cline-sync/utils/get-next-release.ts",
		"prepare": "husky || true",
		"webview:install": "cd webviews/welcome && npm install",
		"webview:dev": "cd webviews/welcome && npm run dev",
		"webview:build": "cd webviews/welcome && npm run build",
		"webview:clean": "cd webviews/welcome && npm run clean",
		"webview:type-check": "cd webviews/welcome && npm run type-check",
		"watch:all": "concurrently \"npm run watch\" \"npm run webview:dev\""
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/eslintrc": "^3.3.3",
		"@eslint/js": "^9.39.2",
		"@estruyf/vscode": "^1.2.0",
		"@langfuse/client": "^4.5.1",
		"@langfuse/otel": "^4.5.1",
		"@langfuse/tracing": "^4.5.1",
		"@opentelemetry/sdk-node": "^0.206.0",
