		"prettier": "^3.8.1",
		"prompts-ncu": "^3.0.2",
		"rimraf": "^6.1.2",
		"shelljs": "^0.8.5",
		"simple-git": "^3.30.0",
		"ts-jest": "^29.2.5",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.18.2"
	},
	"dependencies": {
		"@orama/orama": "^2.0.22",
		"@orama/plugin-data-persistence": "^2.0.22",
		"@salesforce/salesforcedx-vscode-experiments": "^0.2.2",
		"@salesforce/vscode-service-provider": "^1.3.0-rc.6.5",
		"@vscode/codicons": "^0.0.38",
		"agentic-chat": "file:./lib/agentic-chat-0.0.397.tgz",
		"axios": "^1.12.2",
		"diff": "^5.1.0",
		"einstein-shared": "github:forcedotcom/salesforcedx-vscode-einstein-shared#semver:0.3.12",
		"himalaya": "^1.1.0",
		"openai": "^4.46.1",
		"zod": "^3.25.76",
		"semver": "^7.7.2",
		"shiki": "^0.14.4"
	},
	"main": "dist/extension.js",
	"l10n": "./l10n",
	"activationEvents": [
		"workspaceContains:sfdx-project.json"
	],
	"extensionDependencies": [
		"salesforce.salesforcedx-vscode-core"
	],
	"contributes": {
		"submenus": [
			{
				"id": "agentforce.submenu",
				"label": "Agentforce"
			},
			{
				"id": "agentforce.previewSubmenu",
				"label": "%salesforcedx-einstein-gpt.agenticChat.livePreviewDropdown.title%",
				"icon": "$(play)"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "agentforce.plusButtonClicked",
					"group": "navigation@1",
					"when": "activeWebviewPanelId == agentic-chat.TabPanelProvider"
				},
				{
					"command": "agentforce.mcpButtonClicked",
					"group": "navigation@2",
					"when": "activeWebviewPanelId == agentic-chat.TabPanelProvider"
				},
				{
					"command": "agentforce.historyButtonClicked",
					"group": "navigation@3",
					"when": "activeWebviewPanelId == agentic-chat.TabPanelProvider"
				},
				{
					"command": "agentforce.popoutButtonClicked",
					"group": "navigation@4",
					"when": "activeWebviewPanelId == agentic-chat.TabPanelProvider"
				},
				{
					"command": "agentforce.accountButtonClicked",
					"group": "navigation@5",
					"when": "activeWebviewPanelId == agentic-chat.TabPanelProvider"
				},
				{
					"command": "agentforce.settingsButtonClicked",
					"group": "navigation@6",
					"when": "activeWebviewPanelId == agentic-chat.TabPanelProvider"
				}
			],
			"commandPalette": [
				{
					"command": "salesforcedx-einstein-gpt.promptForQuery",
					"when": "editorLangId == 'apex' && salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "salesforcedx-einstein-gpt.displayStatusMenu",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "salesforcedx-einstein-gpt.toggleEinsteinAutoCompletions",
					"title": "%salesforcedx-einstein-gpt.toggleEinsteinAutoCompletions.title%",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "salesforcedx-einstein-gpt.toggleEinsteinAutoCompletionsForCurrentFileType",
					"title": "%salesforcedx-einstein-gpt.toggleEinsteinAutoCompletionsForCurrentFileType.title%",
					"when": "(editorLangId == 'apex'|| editorLangId == 'javascript' || editorLangId == 'css' || editorLangId == 'html') && salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "salesforcedx-einstein-gpt.gettingStarted",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "salesforcedx-einstein-gpt.getLLMServiceInstance",
					"when": "never"
				},
				{
					"command": "agentforce.plusButtonClicked",
					"when": "false"
				},
				{
					"command": "agentforce.mcpButtonClicked",
					"when": "false"
				},
				{
					"command": "agentforce.historyButtonClicked",
					"when": "false"
				},
				{
					"command": "agentforce.popoutButtonClicked",
					"when": "false"
				},
				{
					"command": "agentforce.accountButtonClicked",
					"when": "false"
				},
				{
					"command": "agentforce.settingsButtonClicked",
					"when": "false"
				},
				{
					"command": "agentforce.addToChat",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "agentforce.addTerminalOutputToChat",
					"when": "false"
				},
				{
					"command": "agentforce.focusChatInput",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "agentforce.explainCode",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "agentforce.improveCode",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "agentforce.generateGitCommitMessage",
					"when": "scmProvider == git && salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "agentforce.reviewComment.reply",
					"when": "false"
				},
				{
					"command": "salesforce.einsteinForDevelopers.showWelcomePage",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				},
				{
					"command": "agentforce.refreshAfvSkills",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				}
			],
			"editor/context": [
				{
					"command": "agentforce.addToChat",
					"title": "%salesforcedx-einstein-gpt.agenticChat.addToChat.title%",
					"when": "salesforcedx-einstein-gpt.isEnabled && editorHasSelection"
				}
			],
			"view/title": [
				{
					"submenu": "agentforce.previewSubmenu",
					"group": "navigation@1",
					"when": "view == agentic-chat.SidebarProvider && (salesforcedx-einstein-gpt.isLivePreviewAvailable || salesforcedx-einstein-gpt.isDataVisualizationAvailable)"
				},
				{
					"command": "agentforce.plusButtonClicked",
					"when": "view == agentic-chat.SidebarProvider",
					"group": "navigation@2"
				},
				{
					"command": "agentforce.mcpButtonClicked",
					"when": "view == agentic-chat.SidebarProvider",
					"group": "navigation@3"
				},
				{
					"command": "agentforce.historyButtonClicked",
					"when": "view == agentic-chat.SidebarProvider",
					"group": "navigation@4"
				}
			],
			"agentforce.previewSubmenu": [
				{
					"command": "agentforce.runLivePreview",
					"group": "navigation",
					"title": "%salesforcedx-einstein-gpt.agenticChat.previewButtonClicked.title%",
					"when": "view == agentic-chat.SidebarProvider",
					"enablement": "view == agentic-chat.SidebarProvider && salesforcedx-einstein-gpt.isLivePreviewAvailable"
				},
				{
					"command": "salesforcedx-einstein-gpt.openDataVisualization",
					"group": "navigation",
					"title": "%salesforcedx-einstein-gpt.agenticChat.dataVisualization.title%",
					"when": "view == agentic-chat.SidebarProvider",
					"enablement": "view == agentic-chat.SidebarProvider && salesforcedx-einstein-gpt.isDataVisualizationAvailable"
				}
			],
			"terminal/context": [
				{
					"command": "agentforce.addTerminalOutputToChat",
					"group": "navigation",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				}
			],
			"scm/title": [
				{
					"command": "agentforce.generateGitCommitMessage",
					"group": "navigation",
					"when": "scmProvider == git && salesforcedx-einstein-gpt.isEnabled"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "agentforce.reviewComment.reply",
					"group": "inline",
					"when": "commentController == agentforce-ai-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "agentforce.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == agentforce-ai-review"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "agentic-chat",
					"title": "%salesforcedx-einstein-gpt.activitybar.agentic-chat.title%",
					"icon": "$(vibe-codey)",
					"when": "salesforcedx-einstein-gpt.isEnabled"
				}
			]
		},
		"views": {
			"agentic-chat": [
				{
					"type": "webview",
					"id": "agentic-chat.SidebarProvider",
					"name": ""
				}
			]
		},
		"commands": [
			{
				"command": "salesforcedx-einstein-gpt.gettingStarted",
				"title": "%salesforcedx-einstein-gpt.gettingStarted.title%"
			},
			{
				"command": "salesforcedx-einstein-gpt.openDataVisualization",
				"title": "%salesforcedx-einstein-gpt.agenticChat.dataVisualization.title%",
				"when": "salesforcedx-einstein-gpt.isEnabled",
				"enablement": "salesforcedx-einstein-gpt.isEnabled && salesforcedx-einstein-gpt.isDataVisualizationAvailable"
			},
			{
				"command": "agentforce.runLivePreview",
				"title": "%salesforcedx-einstein-gpt.agenticChat.previewButtonClicked.title%",
				"icon": "$(play)",
				"when": "never",
				"enablement": "salesforcedx-einstein-gpt.isEnabled && salesforcedx-einstein-gpt.isLivePreviewAvailable"
			},
			{
				"command": "salesforcedx-einstein-gpt.promptForQuery",
				"title": "%salesforcedx-einstein-gpt.promptForQuery.title%"
			},
			{
				"command": "salesforcedx-einstein-gpt.acceptSuggestion",
				"title": "%salesforcedx-einstein-gpt.acceptSuggestion.title%",
				"when": "never"
			},
			{
				"command": "salesforcedx-einstein-gpt.clearSuggestion",
				"title": "%salesforcedx-einstein-gpt.clearSuggestion.title%",
				"when": "never"
			},
			{
				"command": "salesforcedx-einstein-gpt.displayStatusMenu",
				"title": "%salesforcedx-einstein-gpt.displayStatusMenu.title%"
			},
			{
				"command": "salesforcedx-einstein-gpt.toggleEinsteinAutoCompletions",
				"title": "%salesforcedx-einstein-gpt.toggleEinsteinAutoCompletions.title%"
			},
			{
				"command": "salesforcedx-einstein-gpt.toggleEinsteinAutoCompletionsForCurrentFileType",
				"title": "%salesforcedx-einstein-gpt.toggleEinsteinAutoCompletionsForCurrentFileType.title%"
			},
			{
				"command": "salesforcedx-einstein-gpt.sobjectRefreshNudge",
				"title": "%salesforcedx-einstein-gpt.sobjectRefreshNudge.title%",
				"when": "never"
			},
			{
				"command": "salesforcedx-einstein-gpt.getLLMServiceInstance",
				"title": "%salesforcedx-einstein-gpt.getLLMServiceInstance.title%",
				"when": "never"
			},
			{
				"command": "agentforce.plusButtonClicked",
				"title": "%salesforcedx-einstein-gpt.agenticChat.plusButtonClicked.title%",
				"icon": "$(add)",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.mcpButtonClicked",
				"title": "%salesforcedx-einstein-gpt.agenticChat.mcpButtonClicked.title%",
				"icon": "$(server)",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.historyButtonClicked",
				"title": "%salesforcedx-einstein-gpt.agenticChat.historyButtonClicked.title%",
				"icon": "$(history)",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.popoutButtonClicked",
				"title": "%salesforcedx-einstein-gpt.agenticChat.popoutButtonClicked.title%",
				"icon": "$(link-external)",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.accountButtonClicked",
				"title": "%salesforcedx-einstein-gpt.agenticChat.accountButtonClicked.title%",
				"icon": "$(account)",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.settingsButtonClicked",
				"title": "%salesforcedx-einstein-gpt.agenticChat.settingsButtonClicked.title%",
				"icon": "$(settings-gear)",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.addToChat",
				"title": "%salesforcedx-einstein-gpt.agenticChat.addToChat.title%",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.addTerminalOutputToChat",
				"title": "%salesforcedx-einstein-gpt.agenticChat.addTerminalOutputToChat.title%",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.focusChatInput",
				"title": "%salesforcedx-einstein-gpt.agenticChat.focusChatInput.title%",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.injectPromptToInput",
				"title": "%salesforcedx-einstein-gpt.agenticChat.injectPromptToInput.title%",
				"when": "false"
			},
			{
				"command": "agentforce.explainCode",
				"title": "%salesforcedx-einstein-gpt.agenticChat.explainCode.title%",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.improveCode",
				"title": "%salesforcedx-einstein-gpt.agenticChat.improveCode.title%",
				"when": "salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.generateGitCommitMessage",
				"title": "%salesforcedx-einstein-gpt.agenticChat.generateGitCommitMessage.title%",
				"icon": "resources/vibe-cody.svg",
				"when": "scmProvider == git && salesforcedx-einstein-gpt.isEnabled"
			},
			{
				"command": "agentforce.reviewComment.reply",
				"title": "Reply",
				"category": "Agentic Chat",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "agentforce.reviewComment.addToChat",
				"title": "Add to Agentforce",
				"category": "Agentic Chat",
				"icon": "$(link-external)"
			},
			{
				"command": "salesforce.einsteinForDevelopers.showWelcomePage",
				"title": "%salesforce.einsteinForDevelopers.showWelcomePage.title%"
			},
			{
				"command": "agentforce.refreshAfvSkills",
				"title": "%agentforce.refreshAfvSkills.title%"
			}
		],
